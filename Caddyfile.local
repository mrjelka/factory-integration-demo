# Local-test variant of the production Caddyfile.
# No domain, no TLS — listens on :80 so http://localhost routes to all services.

:80 {
    root * /srv/landing
    file_server

    handle_path /control* {
        reverse_proxy trigger-ui:8080
    }

    handle /api/* {
        reverse_proxy opcua-server:3001
    }

    handle /grafana* {
        reverse_proxy grafana:3000
    }

    handle_path /influx* {
        reverse_proxy influxdb:8086
    }
}
