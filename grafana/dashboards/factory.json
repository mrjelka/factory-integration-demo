            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "unit": "g"
        },
        "overrides": []
      },
      "targets": [
        {
          "query": "from(bucket: \"factory\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sensor\" and r._field == \"vibration\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
