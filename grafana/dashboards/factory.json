      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "query": "from(bucket: \"factory\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"line\" and r._field == \"parts_produced\")\n  |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "title": "OEE",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: \"factory\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"line\" and r._field == \"oee\")\n  |> last()",
          "refId": "A"
