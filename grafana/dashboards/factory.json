      "targets": [
        {
          "query": "from(bucket: \"factory\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"printer\" and r._field == \"status\")\n  |> last()",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/.*/"
        },
        "textMode": "value",
        "colorMode": "value"
      }
    },
