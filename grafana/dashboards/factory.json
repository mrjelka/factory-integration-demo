          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "query": "from(bucket: \"factory\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"line\" and r._field == \"cycle_time\")\n  |> last()",
