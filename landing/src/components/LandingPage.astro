---
import type { Content } from '../content/types';

interface Props {
  t: Content;
  activeLang: 'en' | 'de';
}

const { t, activeLang } = Astro.props;
---

<header>
  <div class="header-bar">
    <div class="logo"><span>&gt;</span> marek rjelka <span>/</span> factory-demo</div>
    <div class="header-links">
      <a href="/index.html" class={`lang-link${activeLang === 'en' ? ' active' : ''}`}>{t.header.langEn}</a>
      <span class="lang-sep">/</span>
      <a href="/index.de.html" class={`lang-link${activeLang === 'de' ? ' active' : ''}`}>{t.header.langDe}</a>
      <a href="https://linkedin.com/in/marek-rjelka">{t.header.linkedin}</a>
      <a href="https://github.com/mrjelka/factory-integration-demo">{t.header.github}</a>
      <a href={`mailto:${t.header.contactEmail}`}>{t.header.contact}</a>
    </div>
  </div>
</header>

<section class="hero">
  <div class="hero-label"><span class="live-dot"></span> {t.hero.label}</div>
  <h1>{t.hero.titleLine1}<br /><span class="highlight">{t.hero.titleLine2}</span></h1>
  <p class="hero-desc">{t.hero.description}</p>
  <div class="hero-actions">
    <a href="/control" class="btn btn-primary"><span class="btn-icon">&#9881;</span> {t.hero.buttons.control}</a>
    <a href="/grafana/d/factory-demo" class="btn btn-secondary"><span class="btn-icon">&#9636;</span> {t.hero.buttons.grafana}</a>
    <a href="https://github.com/mrjelka/factory-integration-demo" class="btn btn-secondary"><span class="btn-icon">&lt;/&gt;</span> {t.hero.buttons.source}</a>
  </div>
</section>

<section class="section">
  <div class="section-label">{t.architecture.label}</div>
  <div class="arch-diagram">
    <div class="arch-flow">
      {t.architecture.nodes.map((node, i) => (
        <>
          {i > 0 && <div class="arch-arrow">&rarr;</div>}
          <div class="arch-node">
            <div class="arch-node-box">
              <div class="arch-node-name">{node.name}</div>
              <div class="arch-node-tech">{node.tech}</div>
            </div>
            {node.port && <div class="arch-node-port">{node.port}</div>}
          </div>
        </>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="section-label">{t.stack.label}</div>
  <div class="stack-grid">
    {t.stack.items.map((item) => (
      <div class="stack-item">
        <div class="stack-protocol">{item.name}</div>
        <div class="stack-desc">{item.desc}</div>
      </div>
    ))}
  </div>
</section>

<section class="section">
  <div class="section-label">{t.features.label}</div>
  <div class="features-list">
    {t.features.items.map((feature, i) => (
      <div class="feature">
        <div class="feature-num">{String(i + 1).padStart(2, '0')}</div>
        <div>
          <div class="feature-title">{feature.title}</div>
          <div class="feature-desc">{feature.desc}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<footer>
  <div class="footer-grid">
    <div>
      <div class="footer-name">{t.footer.name}</div>
      <div class="footer-title">{t.footer.title}</div>
    </div>
    <div class="footer-links">
      <a href={`mailto:${t.footer.email}`}>{t.footer.email}</a>
      <a href="https://linkedin.com/in/marek-rjelka">LinkedIn</a>
      <a href="https://github.com/marek-rjelka/factory-integration-demo">GitHub</a>
    </div>
  </div>
</footer>
